#!/bin/sh /etc/rc.common

START=98
USE_PROCD=1

start_service() {
	local enabled

	enabled="$(uci -q get wireless_helper.settings.enabled)"
	[ "$enabled" = "1" ] || return 0
	[ -x /usr/libexec/wireless-helper ] || return 0

	procd_open_instance
	procd_set_param command /usr/libexec/wireless-helper clean
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
